# Generate a long random activation code. Never commit the real file.
EMEFA_ENROLLMENT_CODE=replace-with-a-long-random-value
EMEFA_MAX_DEVICES=3

# Optional but required for real AI responses.
EMEFA_DEEPSEEK_API_KEY=
EMEFA_DEEPSEEK_MODEL=deepseek-v4-flash

# Required for the direct, interruptible ElevenLabs voice conversation.
# These values stay on the server and are never sent to the browser.
EMEFA_ELEVENLABS_API_KEY=
EMEFA_ELEVENLABS_AGENT_ID=
