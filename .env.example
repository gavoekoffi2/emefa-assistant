# EMEFA server configuration (copy to .env — never commit the real file).
# All variables use the EMEFA_ prefix and are read by backend/emefa/config.py.

# Generate a long random activation code. Mandatory to enroll a browser/device.
EMEFA_ENROLLMENT_CODE=replace-with-a-long-random-value

# Maximum simultaneously enrolled browsers/devices.
EMEFA_MAX_DEVICES=3

# SQLite database location (Docker deployment uses /app/data/emefa.db on a volume).
EMEFA_DATABASE_PATH=emefa.db

# Set to false only for local HTTP development; must stay true behind TLS.
EMEFA_COOKIE_SECURE=true

# Server-side session/token lifetime in seconds (default 30 days).
EMEFA_SESSION_MAX_AGE_SECONDS=2592000

# Failed-activation lockout: attempts allowed per source in the rolling window.
EMEFA_ACTIVATION_MAX_FAILURES=5
EMEFA_ACTIVATION_WINDOW_SECONDS=900

# Optional but required for real AI responses on /v1/agent/runs.
EMEFA_DEEPSEEK_API_KEY=
EMEFA_DEEPSEEK_MODEL=deepseek-v4-flash

# Required for the direct, interruptible ElevenLabs voice conversation.
# These values stay on the server and are never sent to the browser.
EMEFA_ELEVENLABS_API_KEY=
EMEFA_ELEVENLABS_AGENT_ID=

# Temporary governed email connector (replace with Google Workspace MCP later).
# Email send remains subject to explicit approval in EMEFA.
EMEFA_EMAIL_ACCOUNT=
EMEFA_HIMALAYA_BINARY=himalaya
EMEFA_HIMALAYA_CONFIG=

# Absolute path of the built web app to serve statically (Docker sets /app/web/dist).
# Leave empty in local dev and run `npm run dev` in web/ instead.
EMEFA_WEB_DIST_PATH=
