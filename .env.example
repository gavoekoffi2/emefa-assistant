# EMEFA server configuration (copy to .env — never commit the real file).
# All variables use the EMEFA_ prefix and are read by backend/emefa/config.py.
# Tags: [OBLIGATOIRE] requis au démarrage · [OPTIONNEL] a une valeur par défaut
#       [PRODUCTION] à durcir/activer en production · placeholders sûrs uniquement.

# ── Activation privée ────────────────────────────────────────────────────────
# [OBLIGATOIRE] Code d'activation privé. Générez une valeur longue et aléatoire
# (ex. `openssl rand -hex 32`). Sans lui, aucune session navigateur ne peut être
# activée et l'API reste fermée.
EMEFA_ENROLLMENT_CODE=replace-with-a-long-random-value

# [OPTIONNEL] Nombre maximal de navigateurs/appareils enrôlés simultanément.
EMEFA_MAX_DEVICES=3

# ── Sessions et sécurité ─────────────────────────────────────────────────────
# [PRODUCTION] Doit rester true derrière TLS ; mettre false uniquement pour un
# développement local en HTTP (sinon le cookie de session n'est pas émis).
EMEFA_COOKIE_SECURE=true

# [OPTIONNEL] Durée de vie côté serveur de la session/token, en secondes (30 j).
EMEFA_SESSION_MAX_AGE_SECONDS=2592000

# [OPTIONNEL] Verrouillage anti-brute-force de l'activation : tentatives
# autorisées par source dans la fenêtre glissante, et durée de cette fenêtre (s).
EMEFA_ACTIVATION_MAX_FAILURES=5
EMEFA_ACTIVATION_WINDOW_SECONDS=900

# ── Stockage ─────────────────────────────────────────────────────────────────
# [OPTIONNEL] Emplacement de la base SQLite (le déploiement Docker utilise
# /app/data/emefa.db sur un volume persistant).
EMEFA_DATABASE_PATH=emefa.db

# [PRODUCTION] Chemin absolu du web app compilé à servir en statique (Docker
# monte /app/web/dist). Laisser vide en dev local et lancer `npm run dev` dans web/.
EMEFA_WEB_DIST_PATH=

# ── Moteur agent (LLM) ───────────────────────────────────────────────────────
# [OPTIONNEL] Requis pour de vraies réponses IA sur /v1/agent/runs et la voix
# branchée sur le cerveau EMEFA. Deux fournisseurs possibles : si les deux clés
# sont présentes, DeepSeek direct est prioritaire. Sans clé, l'app reste
# activable mais signale que le moteur de langage n'est pas configuré.
#
# Option A — DeepSeek direct :
EMEFA_DEEPSEEK_API_KEY=
EMEFA_DEEPSEEK_MODEL=deepseek-v4-flash
#
# Option B — OpenRouter (clé `sk-or-…`) :
EMEFA_OPENROUTER_API_KEY=
EMEFA_OPENROUTER_MODEL=deepseek/deepseek-chat
# [OPTIONNEL] URL de base de l'API OpenRouter (rarement à changer).
EMEFA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Voix temps réel (ElevenLabs) ─────────────────────────────────────────────
# [OPTIONNEL] Requis pour la conversation vocale interruptible ElevenLabs. Ces
# valeurs restent sur le serveur et ne sont jamais envoyées au navigateur :
# /v1/realtime/session génère une URL de conversation éphémère après vérification.
EMEFA_ELEVENLABS_API_KEY=
EMEFA_ELEVENLABS_AGENT_ID=

# ── Pont voix → cerveau EMEFA (Custom LLM) ───────────────────────────────────
# [OPTIONNEL] Secret partagé qui authentifie le bridge ElevenLabs → endpoint
# /v1/voice-llm/chat/completions, pour que la voix passe par le moteur gouverné
# d'EMEFA. Générez une valeur longue et aléatoire (ex. `openssl rand -hex 32`) et
# renseignez la même valeur comme clé API du Custom LLM côté ElevenLabs.
EMEFA_VOICE_LLM_TOKEN=

# ── Boîte mail gouvernée (Himalaya) ──────────────────────────────────────────
# [OPTIONNEL] Connecteur e-mail provisoire. Les compétences e-mail n'apparaissent
# dans /v1/system/status que si EMEFA_EMAIL_ACCOUNT est renseigné. Tout envoi
# reste soumis à une approbation explicite dans EMEFA. Les identifiants Himalaya
# restent hors dépôt : seul le nom de compte et les chemins sont configurés ici.
EMEFA_EMAIL_ACCOUNT=
EMEFA_HIMALAYA_BINARY=himalaya
EMEFA_HIMALAYA_CONFIG=

# ── Brief matinal proactif (optionnel) ───────────────────────────────────────
# [OPTIONNEL] Heure locale du serveur (0-23) de génération du brief quotidien.
# Laissée absente/commentée, aucun travail proactif ne s'exécute (comportement
# par défaut). Décommentez avec une heure entière pour activer.
# EMEFA_BRIEF_HOUR=7
# [OPTIONNEL] Adresse qui reçoit le brief chaque matin (nécessite la boîte mail
# ci-dessus). Cette variable vaut approbation permanente et cadrée pour ce seul
# envoi quotidien ; retirez-la (ou laissez-la commentée) pour révoquer.
# EMEFA_BRIEF_EMAIL_TO=vous@example.com
